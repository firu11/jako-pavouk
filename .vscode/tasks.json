{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Tunel",
            "type": "shell",
            "command": "ssh -L 5432:localhost:5432 firu@128.140.124.100",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "panel": "dedicated"
            }
        },
        {
            "label": "Backend run",
            "type": "shell",
            "command": "arelo -p '**/*.go' -p '**/.env' -i '**/*_test.go' -- go run .",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "panel": "dedicated",
                "group": "A"
            }
        },
        {
            "label": "Frontend run",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "panel": "dedicated",
                "group": "A"
            }
        },
        {
            "label": "Pavouk",
            "dependsOn": [
                "Backend run",
                "Frontend run",
                "Tunel"
            ],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "Pavouk 2",
            "dependsOn": [
                "Backend run",
                "Frontend run"
            ],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "showReuseMessage": true,
                "clear": false
            }
        }
    ]
}
